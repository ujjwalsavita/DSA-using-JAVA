***************************************** JAVA *****************************************
public class patter04 {
    public static void main(String[] args) {
        int n = 5;

        for(int i= 1; i <= n; i++){
            // space
            for(int j = 1; j <= n - i; j++){
                System.out.print("  ");
            }

            //students
            for(int j = 1; j <= i; j++){
                System.out.print("* ");
            }

            System.out.println();
        }
    }
}



***************************************** C *****************************************

#include <stdio.h>

int main() {
    int n = 5;

    for(int i = 1; i <= n; i++) {

        // space
        for(int j = 1; j <= n - i; j++) {
            printf("  ");
        }

        // stars
        for(int j = 1; j <= i; j++) {
            printf("* ");
        }

        printf("\n");
    }

    return 0;
}

***************************************** C++ *****************************************
#include <iostream>
using namespace std;

int main() {
    int n = 5;

    for(int i = 1; i <= n; i++) {

        // space
        for(int j = 1; j <= n - i; j++) {
            cout << "  ";
        }

        // stars
        for(int j = 1; j <= i; j++) {
            cout << "* ";
        }

        cout << endl;
    }

    return 0;
}


***************************************** Python *****************************************
n = 5

for i in range(1, n + 1):

    # spaces
    for j in range(1, n - i + 1):
        print("  ", end="")

    # stars
    for j in range(1, i + 1):
        print("* ", end="")

    print()