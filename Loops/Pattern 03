***************************************** JAVA *****************************************
public class pattern03 {
    public static void main(String[] args) {
        int n = 7;

        for(int i = 1; i<= n ;i++){

            for(int j= 1; j <= i; j++){
                System.out.print("* ");
            }
            
            System.out.println();
        }
    }
}


***************************************** C *****************************************
#include <stdio.h>

int main() {
    int n = 7;

    for(int i = 1; i <= n; i++) {

        for(int j = 1; j <= i; j++) {
            printf("* ");
        }

        printf("\n");
    }

    return 0;
}


***************************************** C++ *****************************************
#include <iostream>
using namespace std;

int main() {
    int n = 7;

    for(int i = 1; i <= n; i++) {

        for(int j = 1; j <= i; j++) {
            cout << "* ";
        }

        cout << endl;
    }

    return 0;
}


