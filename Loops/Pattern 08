***************************************** JAVA ****************************************
public class pattern08 {
    public static void main(String[] args) {
        int n = 10;

        for(int i = 1 ; i <= n ;i++){

            //space
            for(int j = 1; j <= i-1 ;j++){
                System.out.print("  ");
            }
            //pattern 
            for(int j = 1; j <= n -i +1; j++){
                System.out.print("* ");
            }

            //Line break
            System.out.println();
        }
    }
}



***************************************** C *******************************************
#include <stdio.h>

int main() {
    int n = 10;

    for(int i = 1; i <= n; i++) {

        // space
        for(int j = 1; j <= i - 1; j++) {
            printf("  ");
        }

        // pattern
        for(int j = 1; j <= n - i + 1; j++) {
            printf("* ");
        }

        printf("\n");
    }

    return 0;
}



***************************************** C++ *****************************************
#include <iostream>
using namespace std;

int main() {
    int n = 10;

    for(int i = 1; i <= n; i++) {

        // space
        for(int j = 1; j <= i - 1; j++) {
            cout << "  ";
        }

        // pattern
        for(int j = 1; j <= n - i + 1; j++) {
            cout << "* ";
        }

        cout << endl;
    }

    return 0;
}


