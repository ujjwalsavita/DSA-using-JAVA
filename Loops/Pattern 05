***************************************** JAVA *****************************************
public class pattern05 {
    public static void main(String[] args) {
        int n = 10;

        for(int i = 1; i<= n ;i++){
            //space 
            for(int j = 1; j <= n - i; j++){
                System.out.print("  ");
            }


            //pattern
            for(int j = 1; j <= 2*i - 1; j++){
                System.out.print("* ");
            }


            //line break
            System.out.println();
        }

    }
}


***************************************** C *****************************************
#include <stdio.h>

int main() {
    int n = 10;

    for(int i = 1; i <= n; i++) {

        // space
        for(int j = 1; j <= n - i; j++) {
            printf("  ");
        }

        // pattern
        for(int j = 1; j <= 2 * i - 1; j++) {
            printf("* ");
        }

        // line break
        printf("\n");
    }

    return 0;
}


***************************************** C++ *****************************************
#include <iostream>
using namespace std;

int main() {
    int n = 10;

    for(int i = 1; i <= n; i++) {

        // space
        for(int j = 1; j <= n - i; j++) {
            cout << "  ";
        }

        // pattern
        for(int j = 1; j <= 2 * i - 1; j++) {
            cout << "* ";
        }

        cout << endl;
    }

    return 0;
}




***************************************** Python *****************************************
n = 10

for i in range(1, n + 1):

    # space
    for j in range(1, n - i + 1):
        print("  ", end="")

    # pattern
    for j in range(1, 2 * i):
        print("* ", end="")

    print()