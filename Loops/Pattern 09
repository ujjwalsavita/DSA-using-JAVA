n = 8

for i in range(1, n + 1):

    # pattern
    for j in range(1, n - i + 2):
        print("* ", end="")

    # space
    for j in range(1, 2 * (i - 1) + 1):
        print("  ", end="")

    # pattern
    for j in range(1, n - i + 2):
        print("* ", end="")

    print()