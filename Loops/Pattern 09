***************************************** C *******************************************
#include <stdio.h>

int main() {
    int n = 8;

    for(int i = 1; i <= n; i++) {

        // pattern
        for(int j = 1; j <= n - i + 1; j++) {
            printf("* ");
        }

        // space
        for(int j = 1; j <= 2 * (i - 1); j++) {
            printf("  ");
        }

        // pattern
        for(int j = 1; j <= n - i + 1; j++) {
            printf("* ");
        }

        printf("\n");
    }

    return 0;
}


***************************************** C++ *****************************************
#include <iostream>
using namespace std;

int main() {
    int n = 8;

    for(int i = 1; i <= n; i++) {

        // pattern
        for(int j = 1; j <= n - i + 1; j++) {
            cout << "* ";
        }

        // space
        for(int j = 1; j <= 2 * (i - 1); j++) {
            cout << "  ";
        }

        // pattern
        for(int j = 1; j <= n - i + 1; j++) {
            cout << "* ";
        }

        cout << endl;
    }

    return 0;
}


