***************************************** JAVA ****************************************
public class SumOfDigits {
    public static void main(String[] args) {
        int n = 9911 ;
        int sum = 0;

        while (n > 0) {
            int r = n % 10;
            n = n / 10;

            sum += r; 
        }

        System.out.println("Sum of the give number is "+sum);

    }
}


