***************************************** JAVA ****************************************
public class pattern07 {
    public static void main(String[] args) {
        int n =7;

        for(int i = 0; i < n ;i++){
            for(int j = 0; j < n - i; j++){
                System.out.print("# ");
            }
            System.out.println(); // new line 
        }
    }   
}




***************************************** C *******************************************
#include <stdio.h>

int main() {
    int n = 7;

    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n - i; j++) {
            printf("# ");
        }
        printf("\n");
    }

    return 0;
}


***************************************** C++ *****************************************
#include <iostream>
using namespace std;

int main() {
    int n = 7;

    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n - i; j++) {
            cout << "# ";
        }
        cout << endl;
    }

    return 0;
}


